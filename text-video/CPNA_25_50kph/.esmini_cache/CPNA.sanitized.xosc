<?xml version='1.0' encoding='utf-8'?>
<OpenSCENARIO xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="OpenSCENARIO.xsd">
  
  <FileHeader revMajor="1" revMinor="3" date="2026-02-24T14:44:00" author="Vector Informatik GmbH" description="Base Scenario CPNA from Euro NCAP Crash Avoidance Frontal Collisions 2026 Protocol">
    <License name="Mozilla Public License Version 2.0" resource="https://www.mozilla.org/en-US/MPL/2.0/" spdxId="MPL-2.0" />
    <Properties>
      <Property name="DYNA4.Version" value="10.0.0" />
    </Properties>
  </FileHeader>
  <ParameterDeclarations>
    <ParameterDeclaration name="ImpactLocation" parameterType="double" value="50">
      
      <ConstraintGroup>
        <ValueConstraint rule="greaterOrEqual" value="10" />
        <ValueConstraint rule="lessOrEqual" value="90" />
      </ConstraintGroup>
    </ParameterDeclaration>
    <ParameterDeclaration name="Ego_length" parameterType="double" value="4.358" />
    <ParameterDeclaration name="Ego_width" parameterType="double" value="1.815">
      
    </ParameterDeclaration>
    <ParameterDeclaration name="Ego_speed_kph" parameterType="double" value="30" />
    <ParameterDeclaration name="Ego_BBcenter_x" parameterType="double" value="1.349" />
    <ParameterDeclaration name="Ego_initTTC" parameterType="double" value="6">
      
      <ConstraintGroup>
        <ValueConstraint value="2.5" rule="greaterThan" />
        
      </ConstraintGroup>
    </ParameterDeclaration>
    <ParameterDeclaration name="VRU_width" parameterType="double" value="0.5" />
    <ParameterDeclaration name="VRU_collisionPointOffset" parameterType="double" value="${0.6/2-0.36}">
      
      
    </ParameterDeclaration>
    <ParameterDeclaration name="VRU_finalSpeed_kph" parameterType="double" value="5" />
    <ParameterDeclaration name="VRU_initS" parameterType="double" value="150">
      
    </ParameterDeclaration>
    <ParameterDeclaration name="VRU_initLatDist" parameterType="double" value="4">
      
    </ParameterDeclaration>
    <ParameterDeclaration name="VRU_accelerationDist" parameterType="double" value="1">
      
    </ParameterDeclaration>
    <ParameterDeclaration name="VRU_trajectoryOrientation" parameterType="int" value="1">
      
      <ConstraintGroup>
        <ValueConstraint value="-1" rule="equalTo" />
      </ConstraintGroup>
      <ConstraintGroup>
        <ValueConstraint value="1" rule="equalTo" />
      </ConstraintGroup>
    </ParameterDeclaration>
    <ParameterDeclaration name="Scenario_ID" parameterType="string" value="CPNA">
      
    </ParameterDeclaration>
    <ParameterDeclaration name="RoadNetwork" parameterType="string" value="/home/alan/esmini-demo_Linux/esmini-demo/OSC-NCAP-scenarios-main/OpenDRIVE/NCAP/StraightRoad_NCAP_noRoadmarks.xodr" />
    <ParameterDeclaration name="LightingConditions" parameterType="string" value="Sunny">
      <ConstraintGroup>
        <ValueConstraint rule="equalTo" value="Sunny" />
      </ConstraintGroup>
      <ConstraintGroup>
        <ValueConstraint rule="equalTo" value="Night" />
      </ConstraintGroup>
    </ParameterDeclaration>
    <ParameterDeclaration name="_Ego_frontBumperLon" parameterType="double" value="${$Ego_BBcenter_x+($Ego_length/2)}">
      
    </ParameterDeclaration>
    <ParameterDeclaration name="_Ego_speed" parameterType="double" value="${$Ego_speed_kph/3.6}">
      
    </ParameterDeclaration>
    <ParameterDeclaration name="_Ego_initS" parameterType="double" value="${$VRU_initS-$Ego_initTTC*$_Ego_speed}">
      
    </ParameterDeclaration>
    <ParameterDeclaration name="_Ego_impactPointOffset" parameterType="double" value="${$Ego_width*($ImpactLocation/100)-$Ego_width/2}">
      
    </ParameterDeclaration>
    <ParameterDeclaration name="_VRU_finalSpeed" parameterType="double" value="${$VRU_finalSpeed_kph/3.6}">
      
    </ParameterDeclaration>
  </ParameterDeclarations>
  <VariableDeclarations>
    <VariableDeclaration name="collisionDetected" variableType="boolean" value="false" />
    <VariableDeclaration name="egoSpeedReached" variableType="double" value="0.0" />
  </VariableDeclarations>
  <CatalogLocations>
    <VehicleCatalog>
      <Directory path="/home/alan/esmini-demo_Linux/esmini-demo/OSC-NCAP-scenarios-main/OpenSCENARIO/NCAP/Catalogs/Vehicles" />
    </VehicleCatalog>
    <PedestrianCatalog>
      <Directory path="/home/alan/esmini-demo_Linux/esmini-demo/OSC-NCAP-scenarios-main/OpenSCENARIO/NCAP/Catalogs/Pedestrians" />
    </PedestrianCatalog>
    <TrajectoryCatalog>
      <Directory path="/home/alan/esmini-demo_Linux/esmini-demo/OSC-NCAP-scenarios-main/OpenSCENARIO/NCAP/Catalogs/Trajectories" />
    </TrajectoryCatalog>
    <ManeuverCatalog>
      <Directory path="/home/alan/esmini-demo_Linux/esmini-demo/OSC-NCAP-scenarios-main/OpenSCENARIO/NCAP/Catalogs/Maneuver" />
    </ManeuverCatalog>
    <EnvironmentCatalog>
      <Directory path="/home/alan/esmini-demo_Linux/esmini-demo/OSC-NCAP-scenarios-main/OpenSCENARIO/NCAP/Catalogs/Environments" />
    </EnvironmentCatalog>
  </CatalogLocations>
  <RoadNetwork>
    <LogicFile filepath="$RoadNetwork" />
  </RoadNetwork>
  <Entities>
    <ScenarioObject name="Ego">
      <CatalogReference entryName="VW_Golf_Sportsvan_2015" catalogName="Vehicles" />
    </ScenarioObject>
    <ScenarioObject name="VRU">
      <CatalogReference entryName="NCAP_Adult" catalogName="Pedestrians" />
    </ScenarioObject>
  </Entities>
  <Storyboard>
    <Init>
      <Actions>
        <GlobalAction>
          <EnvironmentAction>
            <CatalogReference catalogName="Environments" entryName="$LightingConditions" />
          </EnvironmentAction>
        </GlobalAction>
        <Private entityRef="Ego">
          <PrivateAction>
            <TeleportAction>
              <Position>
                <LanePosition roadId="0" laneId="-1" s="$_Ego_initS">
                </LanePosition>
              </Position>
            </TeleportAction>
          </PrivateAction>
          <PrivateAction>
            <LongitudinalAction>
              <SpeedAction>
                <SpeedActionDynamics dynamicsDimension="time" dynamicsShape="step" value="0" />
                <SpeedActionTarget>
                  <AbsoluteTargetSpeed value="$_Ego_speed" />
                </SpeedActionTarget>
              </SpeedAction>
            </LongitudinalAction>
          </PrivateAction>
        </Private>
        <Private entityRef="VRU">
          <PrivateAction>
            <RoutingAction>
              <FollowTrajectoryAction>
                <TimeReference>
                  <None />
                </TimeReference>
                <TrajectoryFollowingMode followingMode="position" />
                <TrajectoryRef>
                  <CatalogReference catalogName="TrajectoryCatalog" entryName="VRU_CPx">
                    <ParameterAssignments>
                      <ParameterAssignment value="$VRU_initS" parameterRef="VRU_initS" />
                      <ParameterAssignment value="${-$VRU_initLatDist}" parameterRef="VRU_latDist" />
                      <ParameterAssignment value="$VRU_trajectoryOrientation" parameterRef="trajectoryOrientation" />
                    </ParameterAssignments>
                  </CatalogReference>
                </TrajectoryRef>
              </FollowTrajectoryAction>
            </RoutingAction>
          </PrivateAction>
        </Private>
      </Actions>
    </Init>
    <Story name="NCAP_CA-FC_CPNA_2026">
      <Act name="Collision_Act">
        <ManeuverGroup name="Synchronization_CollisionDetection" maximumExecutionCount="1">
          <Actors selectTriggeringEntities="false">
            <EntityRef entityRef="VRU" />
          </Actors>
          <CatalogReference catalogName="ManeuverCatalog" entryName="LogAndSetVariables">
            <ParameterAssignments>
              <ParameterAssignment parameterRef="egoSpeed" value="$_Ego_speed" />
            </ParameterAssignments>
          </CatalogReference>
          <Maneuver name="VRU_Synchronization">
            <Event name="VRU_SynchronizeEvent" priority="override">
              <Action name="VRU_SynchronizeAction">
                <PrivateAction>
                  <SynchronizeAction masterEntityRef="Ego">
                    <TargetPositionMaster>
                      <LanePosition roadId="0" laneId="-1" s="${$VRU_initS-$_Ego_frontBumperLon-$VRU_width/2}" />
                    </TargetPositionMaster>
                    <TargetPosition>
                      <TrajectoryPosition s="${$VRU_initLatDist+$_Ego_impactPointOffset-$VRU_collisionPointOffset}">
                        <TrajectoryRef>
                          <CatalogReference catalogName="TrajectoryCatalog" entryName="VRU_CPx">
                            <ParameterAssignments>
                              <ParameterAssignment value="$VRU_initS" parameterRef="VRU_initS" />
                              <ParameterAssignment value="${-$VRU_initLatDist}" parameterRef="VRU_latDist" />
                              <ParameterAssignment value="$VRU_trajectoryOrientation" parameterRef="trajectoryOrientation" />
                            </ParameterAssignments>
                          </CatalogReference>
                        </TrajectoryRef>
                      </TrajectoryPosition>
                    </TargetPosition>
                    <FinalSpeed>
                      <AbsoluteSpeed value="$_VRU_finalSpeed">
                        <TargetDistanceSteadyState distance="${$VRU_initLatDist-$VRU_accelerationDist}" />
                      </AbsoluteSpeed>
                    </FinalSpeed>
                  </SynchronizeAction>
                </PrivateAction>
              </Action>
            </Event>
          </Maneuver>
        </ManeuverGroup>
      </Act>
      </Story>
    <StopTrigger>
      <ConditionGroup>
        <Condition name="StopAfterCollision" delay="1" conditionEdge="none">
          <ByValueCondition>
            <VariableCondition variableRef="collisionDetected" rule="equalTo" value="true" />
          </ByValueCondition>
        </Condition>
      </ConditionGroup>
      <ConditionGroup>
        <Condition name="EgoSpeedReached" delay="1" conditionEdge="none">
          <ByValueCondition>
            <VariableCondition variableRef="egoSpeedReached" rule="greaterThan" value="0" />
          </ByValueCondition>
        </Condition>
        <Condition name="StopAtStandstill" delay="1" conditionEdge="none">
          <ByEntityCondition>
            <TriggeringEntities triggeringEntitiesRule="any">
              <EntityRef entityRef="Ego" />
            </TriggeringEntities>
            <EntityCondition>
              <StandStillCondition duration="0.1" />
            </EntityCondition>
          </ByEntityCondition>
        </Condition>
      </ConditionGroup>
      <ConditionGroup>
        <Condition name="StopAfterCrossingVRUTrajectory" delay="0" conditionEdge="none">
          <ByEntityCondition>
            <TriggeringEntities triggeringEntitiesRule="any">
              <EntityRef entityRef="Ego" />
            </TriggeringEntities>
            <EntityCondition>
              <TraveledDistanceCondition value="${$VRU_initS-$_Ego_initS+5}" />
            </EntityCondition>
          </ByEntityCondition>
        </Condition>
      </ConditionGroup>
    </StopTrigger>
  </Storyboard>
</OpenSCENARIO>